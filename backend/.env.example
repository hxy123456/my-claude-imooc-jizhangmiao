# =============================================================================
# 记账喵 (CountCat) 后端环境变量模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# HTTP 服务端口
PORT=3001

# 运行环境: development | production | test
NODE_ENV=development

# CORS 允许的来源（多个用逗号分隔，例如 http://localhost:3000,http://192.168.1.10:3000）
# 开发期（NODE_ENV=development）会额外放行所有 localhost/127.0.0.1/私网 IP（10.x / 192.168.x / 172.16-31.x）的任意端口
# 生产期（NODE_ENV=production）严格只放行本白名单
CORS_ORIGIN=http://localhost:3001

# -----------------------------------------------------------------------------
# MySQL 数据库配置
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_NAME=countcat
# 连接池配置
DB_CONNECTION_LIMIT=10

# -----------------------------------------------------------------------------
# JWT 鉴权配置
# -----------------------------------------------------------------------------
# 签发 token 时使用的密钥（生产环境务必使用强随机字符串，例: openssl rand -hex 64）
JWT_SECRET=countcat-dev-secret-please-change-in-production
# token 有效期（单位：秒；默认 7 天）
JWT_EXPIRES_IN=604800
# token 签发者
JWT_ISSUER=countcat

# -----------------------------------------------------------------------------
# 密码哈希策略
# V1.0.1 前端使用 SHA-256；V1.1+ 服务端沿用 SHA-256 以便无缝迁移老用户
# 升级到 bcrypt 时设置 PASSWORD_ALGO=bcrypt 并 PASSWORD_BCRYPT_ROUNDS=10
# -----------------------------------------------------------------------------
PASSWORD_ALGO=sha256
PASSWORD_BCRYPT_ROUNDS=10
